<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <RootNamespace>University_Timetable_and_Classroom_Management_System</RootNamespace>
    <Nullable>enable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <ApplicationIcon>Assets\AppIcon.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <EmbeddedResource Remove="PresentationLayer\*.resx" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Guna.UI2.WinForms" Version="2.0.4.8" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Business_Logic_Layer\Business_Logic_Layer.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="Assets\AppIcon.ico">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="Assets\AppLogo.png">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="Assets\AppLogoSquare.png">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <Compile Update="PresentationLayer\BranchesForm.cs">
      <SubType>Code</SubType>
    </Compile>
    <Compile Update="PresentationLayer\ClassroomsForm.cs">
      <SubType>Code</SubType>
    </Compile>
    <Compile Update="PresentationLayer\FacultyMembersForm.cs">
      <SubType>Code</SubType>
    </Compile>
    <Compile Update="PresentationLayer\FacultyMemberSubjectsForm.cs">
      <SubType>Code</SubType>
    </Compile>
    <Compile Update="PresentationLayer\MainShellForm.cs">
      <SubType>Code</SubType>
    </Compile>
    <Compile Update="PresentationLayer\LoginForm.cs">
      <SubType>Code</SubType>
    </Compile>
    <Compile Update="PresentationLayer\RegisterForm.cs">
      <SubType>Code</SubType>
    </Compile>
    <Compile Update="PresentationLayer\SchedulesForm.cs">
      <SubType>Code</SubType>
    </Compile>
    <Compile Update="PresentationLayer\SectionsForm.cs">
      <SubType>Code</SubType>
    </Compile>
    <Compile Update="PresentationLayer\StudyYearsForm.cs">
      <SubType>Code</SubType>
    </Compile>
    <Compile Update="PresentationLayer\SubjectsForm.cs">
      <SubType>Code</SubType>
    </Compile>
    <Compile Update="PresentationLayer\TimeSlotsForm.cs">
      <SubType>Code</SubType>
    </Compile>
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Remove="PresentationLayer\*.resx" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="PresentationLayer\RegisterForm.resx" />
    <EmbeddedResource Include="PresentationLayer\SchedulesForm.Loading.resx" />
    <EmbeddedResource Include="PresentationLayer\SchedulesForm.resx" />
    <EmbeddedResource Include="PresentationLayer\StudyYearsForm.resx" />
  </ItemGroup>

</Project>
